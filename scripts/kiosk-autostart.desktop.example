# Copy to the Pi desktop user's autostart folder, then log out/in or reboot.
#
#   mkdir -p ~/.config/autostart
#   cp scripts/kiosk-autostart.desktop.example ~/.config/autostart/printer-kiosk.desktop
#   chmod +x ~/.config/autostart/printer-kiosk.desktop   # optional
#   nano ~/.config/autostart/printer-kiosk.desktop      # fix Exec if chromium path differs
#
# Opens the app fullscreen on the Pi itself (http://localhost:5173 — same machine as Vite).

[Desktop Entry]
Type=Application
Name=Printer GUI Kiosk
Comment=Fullscreen Chromium to printer UI
Exec=/bin/bash -lc "sleep 10 && chromium --kiosk --disable-infobars --noerrdialogs http://localhost:5173"
# If `chromium` is not found, try: chromium-browser
X-GNOME-Autostart-enabled=true
