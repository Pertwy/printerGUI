# ILI9341 TFT print UI — copy to /etc/systemd/system/tft-print-ui.service, edit paths/user, then:
#   sudo systemctl daemon-reload && sudo systemctl enable --now tft-print-ui.service
#
# Runs direct-to-SPI using luma.lcd (no framebuffer/fbcp-ili9341 required).

[Unit]
Description=ILI9341 TFT printer homepage (PIL + luma.lcd)
After=network-online.target print-server.service
Wants=print-server.service

[Service]
Type=simple
WorkingDirectory=/home/john/Desktop/printerGUI
User=john
# Touch: T_CS = header pin 26 (BCM 7), T_IRQ = pin 11 (BCM 17). Display uses DC=24, RST=25, CS=CE0.
Environment=TFT_TOUCH_CS_GPIO=7
Environment=TFT_TOUCH_IRQ_GPIO=17
Environment=TFT_TOUCH_USE_IRQ=0
ExecStart=/home/john/Desktop/printerGUI/.venv/bin/python3 pi_tft/print_page_tft.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
